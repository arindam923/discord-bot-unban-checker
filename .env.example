DISCORD_TOKEN=your_discord_bot_here

# Optional: channel ID for alerts (rate-limit warnings, aggregate heartbeat).
# Falls back to the first guild's system channel if not set.
# ALERT_CHANNEL_ID=123456789012345678

# The bot checks Instagram ban status via the socialyze.io API
# (https://socialyze.io/api/v1/trackers/instagram-followers). socialyze hosts
# the scraper on their side, so the bot does NOT hit Instagram directly and
# no proxy rotation is needed. socialyze rate-limits by API key, not by IP.
SOCIALYZE_API_KEY=your_socialyze_api_key_here
SOCIALYZE_API_SECRET=your_socialyze_api_secret_here

# How long (in seconds) to wait for socialyze's first scrape after we add a
# tracker before declaring the account banned. socialyze typically scrapes
# within ~30s for live accounts; banned/deleted accounts stay un-scraped.
# Default 300 (5 min). Lower = faster ban detection, higher = false-positive risk.
# SOCIALYZE_SCRAPE_GRACE_SECONDS=300

DISCORD_TOKEN=your_discord_bot_here

# Optional: channel ID for alerts (rate-limit warnings, aggregate heartbeat).
# Falls back to the first guild's system channel if not set.
# ALERT_CHANNEL_ID=123456789012345678

# The bot uses Instagram's own GraphQL API (www.instagram.com) which is free
# and unauthenticated — no API key needed, no monthly quota.
# If Instagram rate-limits your IP (429 / 401 require_login errors), lower
# CHECK_CONCURRENCY in main.py or add a proxy via the PROXY_URLS setting below.

# Optional: comma-separated proxy URLs to spread requests across IPs.
# Two formats are accepted:
#   1) Geonode / sticky-provider style:  host:port:user:pass
#   2) Standard URL form:                http://user:pass@host:port
# Mix-and-match is fine. Each request rotates round-robin across the list.
# PROXY_URLS=proxy.geonode.io:9000:user:pass

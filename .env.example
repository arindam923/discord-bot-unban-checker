DISCORD_TOKEN=your_discord_bot_here

# Optional: residential proxy for Instagram (bypasses datacenter IP blocks)
PROXY_HOST=geo.iproyal.com
PROXY_PORT=12321
PROXY_USER=your_proxy_username
PROXY_PASS=your_proxy_password

# Optional: force every Instagram check through the proxy, skipping the
# smart direct-first fallback. Useful for debugging "is my IP blocked?"
# or testing proxy reliability. Leave unset (or false) to let the bot
# try direct first and only fall back to proxy on real failures.
# FORCE_PROXY=true
